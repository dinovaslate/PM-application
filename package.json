{
  "name": "pmo-risk-capacity-dashboard",
  "private": true,
  "version": "0.1.0",
  "description": "PMO Risk & Capacity Dashboard desktop app",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "desktop": "npm run build && electron .",
    "dist:win": "npm run build && electron-builder --win portable"
  },
  "build": {
    "appId": "com.pmo.risk-capacity-dashboard",
    "productName": "PMO Risk Capacity Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "PMO-Risk-Capacity-Dashboard-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "PMO-Risk-Capacity-Dashboard-${version}-${arch}.${ext}"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@vitejs/plugin-react": "^4.7.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "read-excel-file": "^9.2.0",
    "recharts": "^3.9.0",
    "vite": "^6.4.3"
  },
  "devDependencies": {
    "electron": "^41.7.1",
    "electron-builder": "^24.13.3",
    "playwright": "^1.61.1",
    "tailwindcss": "^4.1.11"
  }
}
